[flake8]
# Flake8 configuration

max-line-length = 100
exclude = 
    .git,
    __pycache__,
    venv,
    env,
    .venv,
    .pytest_cache,
    .hypothesis,
    build,
    dist

ignore = 
    E203,  # whitespace before ':'
    W503,  # line break before binary operator

per-file-ignores =
    __init__.py:F401
