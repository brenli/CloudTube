# ============================================
# CloudTube Configuration
# Your YouTube in the Cloud
# Created by Kir
# ============================================

# --------------------------------------------
# Telegram Bot Configuration
# --------------------------------------------
# Get your bot token from @BotFather on Telegram:
# 1. Open Telegram and search for @BotFather
# 2. Send /newbot and follow instructions
# 3. Copy the token you receive
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram User ID (only you will have access to the bot):
# 1. Open Telegram and search for @userinfobot
# 2. Send /start to get your user ID
# 3. Copy the numeric ID
TELEGRAM_OWNER_ID=your_telegram_id_here

# --------------------------------------------
# Database Configuration
# --------------------------------------------
# Path to SQLite database file
# Development: ./data/bot.db (relative to project root)
# Production: /opt/CloudTube/data/bot.db
DATABASE_PATH=./data/bot.db

# --------------------------------------------
# Download Configuration
# --------------------------------------------
# Temporary directory for downloads before uploading to WebDAV
# Make sure this directory has enough space for video files
# Development: ./temp (relative to project root)
# Production: /opt/CloudTube/temp
TEMP_DOWNLOAD_PATH=./temp

# Maximum number of concurrent downloads
# Recommended values:
# - 2GB RAM: 1-2 concurrent downloads
# - 4GB RAM: 2-3 concurrent downloads
# - 8GB+ RAM: 3-4 concurrent downloads
MAX_CONCURRENT_DOWNLOADS=2

# --------------------------------------------
# Logging Configuration
# --------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# - DEBUG: Very detailed, for development
# - INFO: General information (recommended for production)
# - WARNING: Only warnings and errors
# - ERROR: Only errors
# - CRITICAL: Only critical errors
LOG_LEVEL=INFO

# Path to log files directory
# Logs are automatically rotated at 10MB and kept for 30 days
# Development: ./logs (relative to project root)
# Production: /opt/CloudTube/logs
LOG_PATH=./logs
